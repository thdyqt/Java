<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="mainPane" prefHeight="600.0" prefWidth="900.0" styleClass="main-wrapper" stylesheets="@login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.LoginController">
    <children>

        <HBox fx:id="loginBox" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="500.0" prefWidth="800.0" styleClass="split-container">
            <children>

                <VBox prefWidth="350.0" styleClass="left-branding" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="brand-text" text="DUT HOTEL" />
                        <Label styleClass="brand-tagline" text="Hệ thống quản lý chuẩn quốc tế" />
                    </children>
                </VBox>

                <VBox prefWidth="450.0" spacing="15.0" styleClass="right-form" HBox.hgrow="ALWAYS">
                    <children>

                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="form-title" text="CHÀO MỪNG TRỞ LẠI" />
                                <Label styleClass="form-subtitle" text="Vui lòng đăng nhập để truy cập hệ thống" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="input-label" text="Tên đăng nhập" />
                                <TextField fx:id="txtUsername" promptText="Nhập mã nhân sự..." styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="input-label" text="Mật khẩu" />
                                <!-- Dùng StackPane để đè TextField hiện MK và Button con mắt lên trên PasswordField -->
                                <StackPane alignment="CENTER_RIGHT">
                                    <children>
                                        <TextField fx:id="txtPasswordVisible" promptText="Nhập mật khẩu..." styleClass="input-field" visible="false" />
                                        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." styleClass="input-field" />

                                        <!-- Nút con mắt (không nhận focus khi nhấn Tab để tránh phiền cho user) -->
                                        <Button fx:id="btnTogglePassword" focusTraversable="false" onAction="#handleTogglePassword" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px; -fx-padding: 0 10 0 0;" text="👁" />
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>

                        <!-- Thêm defaultButton="true" để nhận sự kiện phím Enter -->
                        <Button fx:id="btnLogin" defaultButton="true" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" styleClass="login-button" text="ĐĂNG NHẬP" />

                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>