<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="mainPane" prefHeight="750.0" prefWidth="1150.0" spacing="20.0" style="-fx-background-color: #f1f5f9;" stylesheets="@style.css, @table-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.QuanLyPhongController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <VBox>
                    <children>
                        <Label text="QUẢN LÝ PHÒNG" textFill="#0f172a">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Label text="Thiết lập danh sách phòng và loại phòng của khách sạn" textFill="#64748b" />
                    </children>
                </VBox>
                <Pane><HBox.hgrow><Priority fx:constant="ALWAYS" /></HBox.hgrow></Pane>
                <Button fx:id="btnQuanLyLoaiPhong" mnemonicParsing="false" onAction="#handleManageRoomType" prefHeight="45.0" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="⚙ QUẢN LÝ LOẠI PHÒNG">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                </Button>
                <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#handleAddNew" prefHeight="45.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="➕ THÊM PHÒNG MỚI">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                </Button>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <children>
                <VBox prefWidth="300.0" spacing="5.0">
                    <children>
                        <Label text="Tìm kiếm phòng" textFill="#64748b" />
                        <TextField fx:id="txtSearch" prefHeight="35.0" promptText="Nhập số phòng..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>
                <VBox prefWidth="250.0" spacing="5.0">
                    <children>
                        <Label text="Lọc theo loại phòng" textFill="#64748b" />
                        <ComboBox fx:id="cbFilterLoaiPhong" prefHeight="35.0" prefWidth="250.0" style="-fx-background-radius: 8; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                    </children>
                </VBox>
                <Pane><HBox.hgrow><Priority fx:constant="ALWAYS" /></HBox.hgrow></Pane>
            </children>
        </HBox>

        <TableView fx:id="tvPhong" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSoPhong" prefWidth="150.0" text="Số Phòng" />
                <TableColumn fx:id="colLoaiPhong" prefWidth="250.0" text="Loại Phòng" />
                <TableColumn fx:id="colDonGia" prefWidth="200.0" text="Giá Tiền / Ngày" />
                <TableColumn fx:id="colSucChua" prefWidth="150.0" text="Sức Chứa" />
                <TableColumn fx:id="colTrangThai" prefWidth="200.0" text="Trạng Thái Hiện Tại" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #1e293b; -fx-padding: 15; -fx-background-radius: 12;">
            <children>
                <Button fx:id="btnEdit" onAction="#handleEdit" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="📝 SỬA PHÒNG" />
                <Button fx:id="btnToggleStatus" onAction="#handleToggleStatus" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔒 TẠM ĐÓNG PHÒNG" />
            </children>
        </HBox>
    </children>
</VBox>
