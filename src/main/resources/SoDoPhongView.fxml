<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainPane" prefHeight="600.0" prefWidth="900.0" styleClass="main-bg" stylesheets="@sodophong.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.SoDoPhongController">

    <top>
        <HBox styleClass="top-bar" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Tình trạng phòng:" />

                <HBox styleClass="legend-item">
                    <Pane styleClass="color-box, status-trong" />
                    <Label text="Trống" />
                </HBox>
                <HBox styleClass="legend-item">
                    <Pane styleClass="color-box, status-cokhach" />
                    <Label text="Có khách" />
                </HBox>
                <HBox styleClass="legend-item">
                    <Pane styleClass="color-box, status-dondep" />
                    <Label text="Đang dọn" />
                </HBox>
                <HBox styleClass="legend-item">
                    <Pane styleClass="color-box, status-baotri" />
                    <Label text="Bảo trì" />
                </HBox>

                <HBox fx:id="filterBox" alignment="CENTER" styleClass="floor-filter-box">
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" BorderPane.alignment="CENTER">
            <content>
                <FlowPane fx:id="roomGrid" styleClass="room-flowpane">
                    <VBox onMouseClicked="#handleRoomClick" styleClass="room-card, status-trong">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <Label styleClass="room-number" text="101" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <Label styleClass="room-icon" text="🔑" />
                            </HBox>
                            <Label styleClass="room-type" text="STANDARD - 1 Giường Đôi" />
                        </children>
                    </VBox>

                    <VBox onMouseClicked="#handleRoomClick" styleClass="room-card, status-cokhach">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <Label styleClass="room-number" text="102" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <Label styleClass="room-icon" text="🛌" />
                            </HBox>
                            <Label styleClass="room-type" text="DELUXE - Tầng 1" />
                        </children>
                    </VBox>

                    <VBox onMouseClicked="#handleRoomClick" styleClass="room-card, status-dondep">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <Label styleClass="room-number" text="201" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <Label styleClass="room-icon" text="💧" />
                            </HBox>
                            <Label styleClass="room-type" text="SUITE - Tầng 2" />
                        </children>
                    </VBox>

                    <VBox onMouseClicked="#handleRoomClick" styleClass="room-card, status-baotri">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <Label styleClass="room-number" text="202" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <Label styleClass="room-icon" text="🛠" />
                            </HBox>
                            <Label styleClass="room-type" text="STANDARD - Rò nước" />
                        </children>
                    </VBox>

                </FlowPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
